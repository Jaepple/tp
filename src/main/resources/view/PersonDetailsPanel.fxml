<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="8" style="-fx-background-color: #2b2b2b; -fx-padding: 10;">

    <Label text="Person Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <HBox spacing="5">
        <Label text="Name:" style="-fx-text-fill: #3a7bd5; -fx-font-weight: bold;" />
        <Label fx:id="name" style="-fx-text-fill: white;" />
    </HBox>

    <HBox spacing="5">
        <Label text="Phone:" style="-fx-text-fill: #3a7bd5; -fx-font-weight: bold;" />
        <Label fx:id="phone" style="-fx-text-fill: white;" />
    </HBox>

    <HBox spacing="5">
        <Label text="Email:" style="-fx-text-fill: #3a7bd5; -fx-font-weight: bold;" />
        <Label fx:id="email" style="-fx-text-fill: white;" />
    </HBox>

    <HBox spacing="5">
        <Label text="Address:" style="-fx-text-fill: #3a7bd5; -fx-font-weight: bold;" />
        <Label fx:id="address" style="-fx-text-fill: white;" />
    </HBox>
</VBox>